# MongoDB
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=ai_diary

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
VITE_TELEGRAM_BOT_ID=your_bot_id_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/webhook/telegram

# Claude API (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Whisper API (OpenAI)
OPENAI_API_KEY=your_openai_key_here

# JWT
JWT_SECRET_KEY=your_random_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Audio
AUDIO_FILES_PATH=/app/audio_files

# Media
MEDIA_FILES_PATH=/app/media_files

# Cookies (set to false only for local http development)
COOKIE_SECURE=true
